# Copy to .env and adjust. All values have sane defaults in config.ts.

# Port the service listens on inside the container (compose maps 8017 -> this).
PP_PORT=8787

# Issuer name baked into the TokenChallenge. Cosmetic here (verify does not bind
# to it) but keep it equal to the protected origin's hostname for clarity.
PP_ISSUER_NAME=quetre.example.com

# Public origin of the protected site (used only for copy on the activation page).
PP_GATED_ORIGIN=https://quetre.example.com

# Default token quota granted per invite code (admin --quota overrides). A
# code is a balance drawn in batches (see PP_TOKENS_PER_DRAW) across devices
# and sites until empty. Also the default cap for faucet codes (see
# PP_ACCRUAL_PERIOD_MS).
PP_QUOTA_DEFAULT=500

# Tokens per activation draw. /pp/issue-info tells clients to blind-sign
# min(available, this) per activation, so one device doesn't drain the whole
# code — the client remembers the code and draws again when it runs low. A
# client default, not a server cap: /pp/issue accepts any batch up to the
# code's remaining balance. Keep it in the tens — draws of tens of tokens made
# ahead of need keep issuance events temporally decorrelated from redemptions
# (one-token draws would let timing link redemptions back to codes).
PP_TOKENS_PER_DRAW=50

# Faucet codes (admin `new-code --daily N [--cap M]`) accrue N tokens per this
# period, up to the cap, and dispense capped draws of what has built up each
# time they're entered — a reusable, self-refilling code. Default period 24h;
# drop it (e.g. 60000) only to test accrual without waiting a real day.
PP_ACCRUAL_PERIOD_MS=86400000

# Points-metered sessions. A token opens/tops up a session worth
# PP_POINTS_PER_TOKEN; each gated request draws PP_POINTS_PER_REQUEST.
# 2000000 / 1000 = 2000 requests per token. Set them equal for one-token-per-request.
PP_POINTS_PER_TOKEN=100000
PP_POINTS_PER_REQUEST=1000
# Media (images, detected from the request URI) meters cheaper so image-heavy
# browsing doesn't drain a budget, while a direct image scrape still costs
# points. The gate forwards X-Original-URI; the verifier picks the cost.
PP_POINTS_PER_MEDIA_REQUEST=100
# Streaming (audio/video: HLS/DASH segments + manifests, mp4/webm, piped's
# /videoplayback, nitter's /video/) pays the cheapest flat base — it's a floor;
# the real price for streaming is the PP_POINTS_PER_MIB size component below.
PP_POINTS_PER_STREAM_REQUEST=25
# Optional size-based component: extra points per MiB REQUESTED, added to the
# class cost when the request declares its size (Range header forwarded as
# X-PP-Range, or piped/googlevideo range=/clen= query params). Prices streaming
# by bandwidth instead of per-request: e.g. 30 here + €8 per 1000 tokens of
# 1M points ≈ €2.3/TB. No size hint => flat class cost. 0 disables.
#PP_POINTS_PER_MIB=30
# Steer new navigations to re-activate once the TOKEN POOL is within this many
# requests of empty, reserving the buffer to finish in-flight page loads.
PP_REFILL_BUFFER_REQUESTS=6000
# Proactive SESSION top-up threshold, in points. When a live session drops below
# this, the SW spends a token to add PP_POINTS_PER_TOKEN to it — keeping it funded
# for SW-invisible media (video/audio). Size >= the longest single video's request
# cost (200000 = 200 requests ~= a 4-7 min clip). See README "Static assets & media".
PP_SESSION_TOPUP_THRESHOLD=200000
# Per-host overrides of the threshold (JSON object, hostname -> points). Use a
# large value for a video-heavy host so its SW banks a big prefunded session
# (many tokens' worth of unattended-playback runway) while other hosts keep the
# small, more private default. Token value stays global — this pre-pays more,
# it doesn't discount. Requires `proxy_set_header Host $host;` in nginx's
# ^~ /pp/ location so the service sees the real hostname.
#PP_TOPUP_THRESHOLD_OVERRIDES={"piped.example.com":1000000}
# Name of the per-host session cookie (rarely worth changing).
#PP_SESSION_COOKIE=pp_session
# Sessions older than this (or with less than one request's worth of points)
# are swept periodically. Default 30 days. This is also the per-host floor a
# light user pays: once their session is swept, the next visit costs a token.
#PP_SESSION_MAX_AGE_MS=2592000000

# Operator bypass password. When set (non-empty), entering it on the activation
# page — or opening /pp/activate?pw=<password> — mints a signed cookie that lets
# THIS device skip token/session metering entirely (unlimited, spends nothing).
# It is a linkable, non-anonymous escape hatch for your own use; keep it secret.
# Leave empty to disable the feature (the /pp/bypass route then 404s).
PP_BYPASS_PASSWORD=
# Cookie name + lifetime for the bypass grant (default: pp_bypass, 365 days).
#PP_BYPASS_COOKIE=pp_bypass
#PP_BYPASS_MAX_AGE_MS=31536000000

# --- BTCPay purchases (optional) ---------------------------------------------
# Sell invite codes for crypto via a BTCPay Server you run. ALL FOUR values and
# at least one package must be set to enable /pp/buy; leave empty to disable
# (routes 404, pages hidden). Greenfield API key needs only
# btcpay.store.cancreateinvoice + btcpay.store.canviewinvoices on the store.
PP_BTCPAY_URL=
PP_BTCPAY_API_KEY=
PP_BTCPAY_STORE_ID=
# Secret of the store webhook you create in BTCPay pointing at
# <origin>/pp/buy/webhook with events InvoiceSettled, InvoiceExpired,
# InvoiceInvalid.
PP_BTCPAY_WEBHOOK_SECRET=
# Fixed packages, one JSON array. amount is a decimal STRING in the currency.
#PP_BTCPAY_PACKAGES=[{"id":"s","label":"Starter","tokens":500,"amount":"3.00","currency":"EUR"},{"id":"m","label":"Regular","tokens":2000,"amount":"10.00","currency":"EUR"},{"id":"l","label":"Heavy","tokens":5000,"amount":"20.00","currency":"EUR"}]
# Purchase rows (BTCPay invoice <-> minted code link) are deleted this long
# after the code is first revealed, severing the payment<->code link. 0 = never.
#PP_PURCHASE_RETENTION_MS=2592000000

# Debug logging: per-request gate decisions on the server, and (via /pp/config)
# token/session stats from the service worker in the browser console.
#PP_DEBUG=1

# Persisted state (mounted volume). Keys are generated on first run.
PP_DB_PATH=/data/pp.db
PP_KEY_DIR=/data/keys
