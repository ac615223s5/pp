# Copy to .env and adjust. All values have sane defaults in config.ts.

# Port the service listens on inside the container (compose maps 8017 -> this).
PP_PORT=8787

# Issuer name baked into the TokenChallenge. Cosmetic here (verify does not bind
# to it) but keep it equal to the protected origin's hostname for clarity.
PP_ISSUER_NAME=quetre.example.com

# Public origin of the protected site (used only for copy on the activation page).
PP_GATED_ORIGIN=https://quetre.example.com

# Default token quota granted per invite code (admin --quota overrides). The
# browser blind-signs this many tokens at activation (parallelised), so very
# large quotas take time — size to expected usage.
PP_QUOTA_DEFAULT=500

# Points-metered sessions. A token opens/tops up a session worth
# PP_POINTS_PER_TOKEN; each gated request draws PP_POINTS_PER_REQUEST.
# 2000000 / 1000 = 2000 requests per token. Set them equal for one-token-per-request.
PP_POINTS_PER_TOKEN=2000000
PP_POINTS_PER_REQUEST=1000
# Steer new navigations to re-activate once the TOKEN POOL is within this many
# requests of empty, reserving the buffer to finish in-flight page loads.
PP_REFILL_BUFFER_REQUESTS=6000
# Proactive SESSION top-up threshold, in points. When a live session drops below
# this, the SW spends a token to add PP_POINTS_PER_TOKEN to it — keeping it funded
# for SW-invisible media (video/audio). Size >= the longest single video's request
# cost (200000 = 200 requests ~= a 4-7 min clip). See README "Static assets & media".
PP_SESSION_TOPUP_THRESHOLD=200000

# Operator bypass password. When set (non-empty), entering it on the activation
# page — or opening /pp/activate?pw=<password> — mints a signed cookie that lets
# THIS device skip token/session metering entirely (unlimited, spends nothing).
# It is a linkable, non-anonymous escape hatch for your own use; keep it secret.
# Leave empty to disable the feature (the /pp/bypass route then 404s).
PP_BYPASS_PASSWORD=
# Cookie name + lifetime for the bypass grant (default: pp_bypass, 365 days).
#PP_BYPASS_COOKIE=pp_bypass
#PP_BYPASS_MAX_AGE_MS=31536000000

# Persisted state (mounted volume). Keys are generated on first run.
PP_DB_PATH=/data/pp.db
PP_KEY_DIR=/data/keys
