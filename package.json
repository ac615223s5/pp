{
  "name": "pepperbox-privacy-pass",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Anonymous-token (Privacy Pass, RFC 9578 Blind RSA) bot-protection issuer+verifier for pepperbox",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:client",
    "build:client": "esbuild client/activate.ts client/pp-worker.ts --bundle --format=iife --target=es2020 --outdir=public",
    "start": "node dist/server.js",
    "admin": "node dist/admin.js"
  },
  "dependencies": {
    "@cloudflare/privacypass-ts": "0.9.0",
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "esbuild": "^0.24.2",
    "typescript": "~5.6.3"
  }
}
